API_KEY=your_neis_api_key
PORT=8000

MONGODB_URI=mongodb://userID:password@host:27017/discord_bot?authSource=admin
DATA_ENCRYPTION_KEY=base64_32_byte_key

ADMIN_ID=admin
ADMIN_PASSWORD=change_this_password
ADMIN_AUTH_KEY=change_this_admin_key
ADMIN_VISIBLE_USER_ID=your_admin_user_id
WEBHOOK_URL=

FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# Enable Firebase Authentication providers: Phone and Google.

ENABLE_TEST_PHONE_AUTH= #테스트 중일 경우 true로 설정, 완료 후 false로 변경
PHONE_AUTH_TEST_TOKEN=
PHONE_AUTH_TEST_UID=test-phone-user
PHONE_AUTH_TEST_PHONE=+821012345678
